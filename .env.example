# Supabase — copy this file to `.env` and fill in your own values.
# Both are exposed to the client at runtime via `process.env.EXPO_PUBLIC_*`.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Google Sign-In — values come from Google Cloud Console OAuth 2.0 Client IDs.
# The Android SDK derives its client from the Web client ID + package +
# SHA fingerprint (no Android client ID at runtime).
# Apple has no client-side secrets — Supabase handles the Apple flow server-side.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
