{
  "lessons": [
    {
      "id": "lesson-01-greetings",
      "title": "Daily greetings",
      "subtitle": "Namaskara & common phrases",
      "thumbnailChar": "ನ",
      "totalPhrases": 6,
      "estimatedMinutes": 5,
      "culturalNote": {
        "label": "Karnataka culture",
        "text": "Namaskara is used at any time of day and with anyone — young, old, stranger or friend. It shows respect and warmth simultaneously."
      },
      "phrases": [
        {
          "id": "phrase-01-01",
          "script": "ನಮಸ್ಕಾರ",
          "roman": "Namaskāra",
          "meaning": "Hello / Greetings",
          "audioFile": "lesson_01_namaskara.mp3"
        },
        {
          "id": "phrase-01-02",
          "script": "ಹೇಗಿದ್ದೀರಾ?",
          "roman": "Hēgiddīrā?",
          "meaning": "How are you?",
          "audioFile": "lesson_01_hegiddira.mp3"
        },
        {
          "id": "phrase-01-03",
          "script": "ನಾನು ಚೆನ್ನಾಗಿದ್ದೇನೆ",
          "roman": "Nānu chennāgiddēne",
          "meaning": "I am fine",
          "audioFile": "lesson_01_nanu_chennagiddene.mp3"
        },
        {
          "id": "phrase-01-04",
          "script": "ಶುಭ ಮುಂಜಾನೆ",
          "roman": "Shubha munjāne",
          "meaning": "Good morning",
          "audioFile": "lesson_01_shubha_munjane.mp3"
        },
        {
          "id": "phrase-01-05",
          "script": "ಶುಭ ರಾತ್ರಿ",
          "roman": "Shubha rātri",
          "meaning": "Good night",
          "audioFile": "lesson_01_shubha_ratri.mp3"
        },
        {
          "id": "phrase-01-06",
          "script": "ಹೋಗಿ ಬರುತ್ತೇನೆ",
          "roman": "Hōgi baruttēne",
          "meaning": "I'll take leave / Goodbye",
          "audioFile": "lesson_01_hogi_baruttene.mp3"
        }
      ]
    },
    {
      "id": "lesson-02-please-thanks",
      "title": "Please & thank you",
      "subtitle": "Dhanyavada & polite phrases",
      "thumbnailChar": "ಧ",
      "totalPhrases": 6,
      "estimatedMinutes": 5,
      "culturalNote": {
        "label": "Karnataka culture",
        "text": "Kannadigas appreciate politeness deeply. Using 'dayavittu' (please) softens any request and instantly signals warmth and respect."
      },
      "phrases": [
        {
          "id": "phrase-02-01",
          "script": "ಧನ್ಯವಾದ",
          "roman": "Dhanyavāda",
          "meaning": "Thank you",
          "audioFile": "lesson_02_dhanyavada.mp3"
        },
        {
          "id": "phrase-02-02",
          "script": "ದಯವಿಟ್ಟು",
          "roman": "Dayavittu",
          "meaning": "Please",
          "audioFile": "lesson_02_dayavittu.mp3"
        },
        {
          "id": "phrase-02-03",
          "script": "ಕ್ಷಮಿಸಿ",
          "roman": "Kshamisi",
          "meaning": "Sorry / Excuse me",
          "audioFile": "lesson_02_kshamisi.mp3"
        },
        {
          "id": "phrase-02-04",
          "script": "ಪರವಾಗಿಲ್ಲ",
          "roman": "Paravāgilla",
          "meaning": "It's okay / No problem",
          "audioFile": "lesson_02_paravagilla.mp3"
        },
        {
          "id": "phrase-02-05",
          "script": "ಹೌದು",
          "roman": "Haudu",
          "meaning": "Yes",
          "audioFile": "lesson_02_haudu.mp3"
        },
        {
          "id": "phrase-02-06",
          "script": "ಇಲ್ಲ",
          "roman": "Illa",
          "meaning": "No",
          "audioFile": "lesson_02_illa.mp3"
        }
      ]
    },
    {
      "id": "lesson-03-directions",
      "title": "Asking directions",
      "subtitle": "Navigate like a local",
      "thumbnailChar": "ಎ",
      "totalPhrases": 6,
      "estimatedMinutes": 6,
      "culturalNote": {
        "label": "Karnataka culture",
        "text": "In Bengaluru, people love helping with directions. Start with 'Namaskara' and locals will go out of their way to guide you — sometimes even walking you there."
      },
      "phrases": [
        {
          "id": "phrase-03-01",
          "script": "ಎಲ್ಲಿದೆ?",
          "roman": "Ellide?",
          "meaning": "Where is it?",
          "audioFile": "lesson_03_ellide.mp3"
        },
        {
          "id": "phrase-03-02",
          "script": "ಎಷ್ಟು ದೂರ?",
          "roman": "Eshtu dūra?",
          "meaning": "How far is it?",
          "audioFile": "lesson_03_eshtu_dura.mp3"
        },
        {
          "id": "phrase-03-03",
          "script": "ಎಡಕ್ಕೆ",
          "roman": "Edakke",
          "meaning": "To the left",
          "audioFile": "lesson_03_edakke.mp3"
        },
        {
          "id": "phrase-03-04",
          "script": "ಬಲಕ್ಕೆ",
          "roman": "Balakke",
          "meaning": "To the right",
          "audioFile": "lesson_03_balakke.mp3"
        },
        {
          "id": "phrase-03-05",
          "script": "ನೇರವಾಗಿ",
          "roman": "Nēravāgi",
          "meaning": "Straight ahead",
          "audioFile": "lesson_03_neravagi.mp3"
        },
        {
          "id": "phrase-03-06",
          "script": "ಬಸ್ ನಿಲ್ದಾಣ ಎಲ್ಲಿದೆ?",
          "roman": "Bus nildāṇa ellide?",
          "meaning": "Where is the bus stop?",
          "audioFile": "lesson_03_bus_nildana_ellide.mp3"
        }
      ]
    },
    {
      "id": "lesson-04-food",
      "title": "Ordering food",
      "subtitle": "Eat your way through Bengaluru",
      "thumbnailChar": "ಊ",
      "totalPhrases": 6,
      "estimatedMinutes": 6,
      "culturalNote": {
        "label": "Karnataka culture",
        "text": "Bengaluru's darshinis (standing restaurants) serve incredible food fast. Knowing a few Kannada words transforms your ordering experience — and earns you a warm smile."
      },
      "phrases": [
        {
          "id": "phrase-04-01",
          "script": "ನನಗೆ ಬೇಕು",
          "roman": "Nanage bēku",
          "meaning": "I want / I need",
          "audioFile": "lesson_04_nanage_beku.mp3"
        },
        {
          "id": "phrase-04-02",
          "script": "ಎಷ್ಟು?",
          "roman": "Eshtu?",
          "meaning": "How much?",
          "audioFile": "lesson_04_eshtu.mp3"
        },
        {
          "id": "phrase-04-03",
          "script": "ಕೊಡಿ",
          "roman": "Koḍi",
          "meaning": "Please give me",
          "audioFile": "lesson_04_kodi.mp3"
        },
        {
          "id": "phrase-04-04",
          "script": "ನೀರು",
          "roman": "Nīru",
          "meaning": "Water",
          "audioFile": "lesson_04_niru.mp3"
        },
        {
          "id": "phrase-04-05",
          "script": "ಕಾಫಿ",
          "roman": "Kāphi",
          "meaning": "Coffee",
          "audioFile": "lesson_04_kaphi.mp3"
        },
        {
          "id": "phrase-04-06",
          "script": "ತುಂಬಾ ಚೆನ್ನಾಗಿದೆ",
          "roman": "Tumbā chennāgide",
          "meaning": "It's very good",
          "audioFile": "lesson_04_tumba_chennagide.mp3"
        }
      ]
    },
    {
      "id": "lesson-05-numbers",
      "title": "Numbers 1–10",
      "subtitle": "Count in Kannada",
      "thumbnailChar": "ಸ",
      "totalPhrases": 10,
      "estimatedMinutes": 7,
      "culturalNote": {
        "label": "Karnataka culture",
        "text": "Knowing numbers in Kannada is a superpower at local markets. Vendors light up when you count in Kannada — it's a sign of effort and respect."
      },
      "phrases": [
        {
          "id": "phrase-05-01",
          "script": "ಒಂದು",
          "roman": "Ondu",
          "meaning": "One",
          "audioFile": "lesson_05_ondu.mp3"
        },
        {
          "id": "phrase-05-02",
          "script": "ಎರಡು",
          "roman": "Eraḍu",
          "meaning": "Two",
          "audioFile": "lesson_05_eradu.mp3"
        },
        {
          "id": "phrase-05-03",
          "script": "ಮೂರು",
          "roman": "Mūru",
          "meaning": "Three",
          "audioFile": "lesson_05_muru.mp3"
        },
        {
          "id": "phrase-05-04",
          "script": "ನಾಲ್ಕು",
          "roman": "Nālku",
          "meaning": "Four",
          "audioFile": "lesson_05_nalku.mp3"
        },
        {
          "id": "phrase-05-05",
          "script": "ಐದು",
          "roman": "Aidu",
          "meaning": "Five",
          "audioFile": "lesson_05_aidu.mp3"
        },
        {
          "id": "phrase-05-06",
          "script": "ಆರು",
          "roman": "Āru",
          "meaning": "Six",
          "audioFile": "lesson_05_aru.mp3"
        },
        {
          "id": "phrase-05-07",
          "script": "ಏಳು",
          "roman": "Ēḷu",
          "meaning": "Seven",
          "audioFile": "lesson_05_elu.mp3"
        },
        {
          "id": "phrase-05-08",
          "script": "ಎಂಟು",
          "roman": "Enṭu",
          "meaning": "Eight",
          "audioFile": "lesson_05_entu.mp3"
        },
        {
          "id": "phrase-05-09",
          "script": "ಒಂಬತ್ತು",
          "roman": "Ombattu",
          "meaning": "Nine",
          "audioFile": "lesson_05_ombattu.mp3"
        },
        {
          "id": "phrase-05-10",
          "script": "ಹತ್ತು",
          "roman": "Hattu",
          "meaning": "Ten",
          "audioFile": "lesson_05_hattu.mp3"
        }
      ]
    }
  ]
}
