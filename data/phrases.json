    "phrase-04-04": { "script": "ನೀರು", "roman": "Nīru", "meaning": "Water", "audioFile": "lesson_04_niru.mp3", "lessonId": "lesson-04-food" },
    "phrase-04-05": { "script": "ಕಾಫಿ", "roman": "Kāphi", "meaning": "Coffee", "audioFile": "lesson_04_kaphi.mp3", "lessonId": "lesson-04-food" },
    "phrase-04-06": { "script": "ತುಂಬಾ ಚೆನ್ನಾಗಿದೆ", "roman": "Tumbā chennāgide", "meaning": "It's very good", "audioFile": "lesson_04_tumba_chennagide.mp3", "lessonId": "lesson-04-food" },
    "phrase-05-01": { "script": "ಒಂದು", "roman": "Ondu", "meaning": "One", "audioFile": "lesson_05_ondu.mp3", "lessonId": "lesson-05-numbers" },
