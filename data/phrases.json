{
  "phrases": {
    "phrase-01-01": { "script": "ನಮಸ್ಕಾರ", "roman": "Namaskāra", "meaning": "Hello / Greetings", "audioFile": "lesson_01_namaskara.mp3", "lessonId": "lesson-01-greetings" },
    "phrase-01-02": { "script": "ಹೇಗಿದ್ದೀರಾ?", "roman": "Hēgiddīrā?", "meaning": "How are you?", "audioFile": "lesson_01_hegiddira.mp3", "lessonId": "lesson-01-greetings" },
    "phrase-01-03": { "script": "ನಾನು ಚೆನ್ನಾಗಿದ್ದೇನೆ", "roman": "Nānu chennāgiddēne", "meaning": "I am fine", "audioFile": "lesson_01_nanu_chennagiddene.mp3", "lessonId": "lesson-01-greetings" },
    "phrase-01-04": { "script": "ಶುಭ ಮುಂಜಾನೆ", "roman": "Shubha munjāne", "meaning": "Good morning", "audioFile": "lesson_01_shubha_munjane.mp3", "lessonId": "lesson-01-greetings" },
    "phrase-01-05": { "script": "ಶುಭ ರಾತ್ರಿ", "roman": "Shubha rātri", "meaning": "Good night", "audioFile": "lesson_01_shubha_ratri.mp3", "lessonId": "lesson-01-greetings" },
    "phrase-01-06": { "script": "ಹೋಗಿ ಬರುತ್ತೇನೆ", "roman": "Hōgi baruttēne", "meaning": "I'll take leave / Goodbye", "audioFile": "lesson_01_hogi_baruttene.mp3", "lessonId": "lesson-01-greetings" },
    "phrase-02-01": { "script": "ಧನ್ಯವಾದ", "roman": "Dhanyavāda", "meaning": "Thank you", "audioFile": "lesson_02_dhanyavada.mp3", "lessonId": "lesson-02-please-thanks" },
    "phrase-02-02": { "script": "ದಯವಿಟ್ಟು", "roman": "Dayavittu", "meaning": "Please", "audioFile": "lesson_02_dayavittu.mp3", "lessonId": "lesson-02-please-thanks" },
    "phrase-02-03": { "script": "ಕ್ಷಮಿಸಿ", "roman": "Kshamisi", "meaning": "Sorry / Excuse me", "audioFile": "lesson_02_kshamisi.mp3", "lessonId": "lesson-02-please-thanks" },
    "phrase-02-04": { "script": "ಪರವಾಗಿಲ್ಲ", "roman": "Paravāgilla", "meaning": "It's okay / No problem", "audioFile": "lesson_02_paravagilla.mp3", "lessonId": "lesson-02-please-thanks" },
    "phrase-02-05": { "script": "ಹೌದು", "roman": "Haudu", "meaning": "Yes", "audioFile": "lesson_02_haudu.mp3", "lessonId": "lesson-02-please-thanks" },
    "phrase-02-06": { "script": "ಇಲ್ಲ", "roman": "Illa", "meaning": "No", "audioFile": "lesson_02_illa.mp3", "lessonId": "lesson-02-please-thanks" },
    "phrase-03-01": { "script": "ಎಲ್ಲಿದೆ?", "roman": "Ellide?", "meaning": "Where is it?", "audioFile": "lesson_03_ellide.mp3", "lessonId": "lesson-03-directions" },
    "phrase-03-02": { "script": "ಎಷ್ಟು ದೂರ?", "roman": "Eshtu dūra?", "meaning": "How far is it?", "audioFile": "lesson_03_eshtu_dura.mp3", "lessonId": "lesson-03-directions" },
    "phrase-03-03": { "script": "ಎಡಕ್ಕೆ", "roman": "Edakke", "meaning": "To the left", "audioFile": "lesson_03_edakke.mp3", "lessonId": "lesson-03-directions" },
    "phrase-03-04": { "script": "ಬಲಕ್ಕೆ", "roman": "Balakke", "meaning": "To the right", "audioFile": "lesson_03_balakke.mp3", "lessonId": "lesson-03-directions" },
    "phrase-03-05": { "script": "ನೇರವಾಗಿ", "roman": "Nēravāgi", "meaning": "Straight ahead", "audioFile": "lesson_03_neravagi.mp3", "lessonId": "lesson-03-directions" },
    "phrase-03-06": { "script": "ಬಸ್ ನಿಲ್ದಾಣ ಎಲ್ಲಿದೆ?", "roman": "Bus nildāṇa ellide?", "meaning": "Where is the bus stop?", "audioFile": "lesson_03_bus_nildana_ellide.mp3", "lessonId": "lesson-03-directions" },
    "phrase-04-01": { "script": "ನನಗೆ ಬೇಕು", "roman": "Nanage bēku", "meaning": "I want / I need", "audioFile": "lesson_04_nanage_beku.mp3", "lessonId": "lesson-04-food" },
